{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/xmszm/skills/yunxiao-workitem/schema/yunxiao-workitem.schema.json",
  "title": "yunxiao-workitem config",
  "type": "object",
  "required": [
    "version",
    "organization_id",
    "project_id",
    "project_code",
    "owners",
    "statuses"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "organization": {
      "type": "string"
    },
    "organization_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": "string"
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "project_code": {
      "type": "string",
      "minLength": 1
    },
    "default_query": {
      "type": "string"
    },
    "owners": {
      "type": "object",
      "properties": {
        "backend": { "type": "string" },
        "ui_product": { "type": "string" },
        "qa": { "type": "string" }
      },
      "additionalProperties": true
    },
    "work_item_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "status", "id", "meaning"],
        "properties": {
          "type": { "type": "string" },
          "status": { "type": "string" },
          "id": { "type": "string" },
          "meaning": {
            "type": "string",
            "enum": ["unfinished", "active", "terminal", "unknown"]
          }
        },
        "additionalProperties": true
      }
    },
    "unfinished_statuses": {
      "type": "string"
    },
    "active_status": {
      "type": "string"
    },
    "repository_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "production_targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reference_targets": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status_policy": {
      "type": "string"
    },
    "implementation_rules": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validations": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": { "type": "string" }
      }
    },
    "runtime_limits": {
      "type": "object",
      "properties": {
        "query_page_size": { "type": "integer", "minimum": 1 },
        "max_enrich_per_round": { "type": "integer", "minimum": 1 },
        "max_implement_per_round": { "type": "integer", "minimum": 0 },
        "max_trellis_tasks_per_round": { "type": "integer", "minimum": 1 },
        "stop_after_code_change": { "type": "boolean" },
        "full_requires_explicit_confirmation": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "trellis_intake": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "image_root": {
          "type": "string",
          "default": "system-cache",
          "description": "Local cache root for downloaded Yunxiao screenshots. Use 'system-cache' to resolve to the OS cache directory (Windows LOCALAPPDATA, macOS Library/Caches, Linux XDG_CACHE_HOME or ~/.cache). Use project paths only when binary evidence should be versioned intentionally."
        },
        "create_parent_task_for_full": { "type": "boolean" },
        "leave_yunxiao_unchanged": { "type": "boolean" },
        "full_drain_until_no_creatable": { "type": "boolean" },
        "full_execute_after_intake": { "type": "boolean" },
        "writeback_after_task_done": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "runtime_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "final_fields": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
